<Window x:Class="zd3_Melekhova_Marina.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zd3_Melekhova_Marina"
        mc:Ignorable="d"
        Title="Плейлист" Height="600" Width="900">
    <DockPanel>
        <!-- Верхнее меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="ExitMenuItem_Click"/>
            </MenuItem>

            <MenuItem Header="Плейлист">
                <MenuItem Header="Следующая песня" Click="NextMenuItem_Click"/>
                <MenuItem Header="Предыдущая песня" Click="PrevMenuItem_Click"/>
                <MenuItem Header="В начало списка" Click="StartMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Перейти по индексу" Click="GoToIndexMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Удалить выбранную" Click="RemoveMenuItem_Click"/>
                <MenuItem Header="Удалить по значению" Click="RemoveByValueMenuItem_Click"/>
                <MenuItem Header="Очистить весь плейлист" Click="ClearMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: список песен -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="5">
                <StackPanel>
                    <TextBlock Text="Список песен" FontWeight="Bold" FontSize="14" 
                               Margin="10,10,10,5" Background="LightGray" Padding="5"/>
                    <ListBox x:Name="lbSongs" Height="350" Margin="10" 
                             SelectionChanged="LbSongs_SelectionChanged"/>
                    <TextBlock x:Name="lblCurrent" Margin="10,5,10,10" 
                               FontWeight="Bold" Foreground="DarkBlue"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Правая панель: поля для ввода -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="5">
                <StackPanel Margin="10">
                    <TextBlock Text="Добавление песни" FontWeight="Bold" FontSize="14" 
                               Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <TextBlock Text="Автор:" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtAuthor" Height="25" Margin="5"/>

                    <TextBlock Text="Название:" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtTitle" Height="25" Margin="5"/>

                    <TextBlock Text="Путь к файлу:" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtFilename" Height="25" Margin="5"/>

                    <Button x:Name="btnAdd" Content="Добавить песню" 
                            Background="LightGreen" Height="35" Margin="5,15,5,5"
                            Click="BtnAdd_Click"/>
                    <Button x:Name="btnAddTest" Content="Добавить тестовую" 
                            Background="LightBlue" Height="35" Margin="5,5,5,5"
                            Click="BtnAddTest_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
